PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/clock_stopwatch_db
CLIENT_ORIGIN=http://localhost:5173

# Secret used to sign JWTs — use a long random string in production
# (e.g. `openssl rand -hex 32`), and never commit the real value.
JWT_SECRET="MY_SECRET_KEY"
JWT_EXPIRES_IN=7d

# bcrypt salt rounds — 10-12 is a good default (higher = slower/more secure)
BCRYPT_SALT_ROUNDS=12
